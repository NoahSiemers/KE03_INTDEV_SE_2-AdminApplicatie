@model KE03_INTDEV_SE_2_Base.ViewModels.OrderDetailsViewModel

@{
    ViewData["Title"] = "Bestelling details";
}

<section class="products-page">
    <div class="detail-back-row">
        <a asp-controller="Orders" asp-action="Index" class="btn-light">
            <i class="fa-solid fa-arrow-left"></i>
            Terug naar overzicht
        </a>
    </div>

    <div class="page-header">
        <h1>Bestelling #@Model.Id</h1>
    </div>

    <div class="order-detail-grid">
        <div class="order-detail-card">
            <h2>Klantgegevens</h2>

            <dl class="order-detail-list">
                <dt>Klant</dt>
                <dd>@Model.CustomerName</dd>

                <dt>Naam</dt>
                <dd>@Model.FullName</dd>

                <dt>Besteldatum</dt>
                <dd>@Model.OrderDate.ToString("dd-MM-yyyy")</dd>
            </dl>
        </div>

        <div class="order-detail-card">
            <h2>Adres en totaal</h2>

            <dl class="order-detail-list">
                <dt>Adres</dt>
                <dd>@Model.AddressLine</dd>

                <dt>Postcode en stad</dt>
                <dd>@Model.PostalCode @Model.City</dd>

                <dt>Totaal</dt>
                <dd>€ @Model.TotalPrice.ToString("0.00")</dd>
            </dl>
        </div>
    </div>

    <div class="order-status-panel">
        <div class="order-status-panel-header">
            <div>
                <h2>Status en bezorging</h2>
                <p>Volg en wijzig hier de afhandeling van deze bestelling.</p>
            </div>

            <span class="order-status">@Model.Status</span>
        </div>

        <form asp-controller="Orders" asp-action="UpdateStatus" method="post" class="order-status-form">
            @Html.AntiForgeryToken()

            <input type="hidden" name="id" value="@Model.Id" />

            <div>
                <label for="status">Nieuwe status</label>

                <select id="status" name="status">
                    @foreach (string status in Model.AvailableStatuses)
                    {
                        if (status == Model.Status)
                        {
                            <option value="@status" selected>@status</option>
                        }
                        else
                        {
                            <option value="@status">@status</option>
                        }
                    }
                </select>

                <label for="depo">Depo</label>

                <select id="depo" name="depo">
                    
                </select>

                <label for="region">Regio</label>

                <select id="region" name="region">

                </select>
            </div>

            <button type="submit">Status opslaan</button>
        </form>

        <div class="order-tracking-grid">
            <div>
                <span>Huidige status</span>
                <strong>@Model.Status</strong>
            </div>

            <div>
                <span>Track & trace</span>
                <strong>@Model.TrackAndTraceCode</strong>
            </div>

            <div>
                <span>Verwachte levering</span>
                <strong>@Model.ExpectedDeliveryDate.ToString("dd-MM-yyyy")</strong>
            </div>
        </div>
    </div>

    <div class="product-table-wrapper">
        <table class="product-table">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Ingepakt</th>
                    <th>Aantal</th>
                    <th>Prijs per stuk</th>
                    <th>Subtotaal</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Items.Any())
                {
                    foreach (OrderItemViewModel item in Model.Items)
                    {
                        <tr>
                            <td class="product-name">@item.ProductName</td>

                            <td>
                                <label class="packed-toggle">

                                    <input type="checkbox"
                                           class="packed-checkbox"
                                           data-order="@Model.Id"
                                           data-product="@item.ProductName"
                                    @(item.IsPacked ? "checked" : "") />

                                    <i class="fa-solid @(item.IsPacked ? "fa-square-check" : "fa-square")"></i>

                                </label>
                            </td>

                            <td>@item.Amount</td>
                            <td>€ @item.PriceAtOrder.ToString("0.00")</td>
                            <td>€ @item.Subtotal.ToString("0.00")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="empty-table">
                            Deze bestelling heeft geen producten.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <script>
        const packedCheckboxes = document.querySelectorAll(".packed-checkbox");
        const statusSelect = document.getElementById("status");
        const depoSelect = document.getElementById("depo");
        const regionSelect = document.getElementById("region");

        const depoLabel = document.querySelector('label[for="depo"]');
        const regionLabel = document.querySelector('label[for="region"]');

        function updateIcon(box) {
            const icon = box.nextElementSibling;

            if (box.checked) {
                icon.className = "fa-solid fa-square-check";
                icon.style.color = "#16a34a"; // green
            } else {
                icon.className = "fa-regular fa-square";
                icon.style.color = "#dc2626"; // red
            }
        }

        function updateStatusAvailability() {
            const allPacked =
                packedCheckboxes.length > 0 &&
                Array.from(packedCheckboxes).every(box => box.checked);

            statusSelect.disabled = !allPacked;

            if (allPacked) {
                statusSelect.style.opacity = "1";
                statusSelect.style.cursor = "pointer";
            } else {
                statusSelect.style.opacity = "0.6";
                statusSelect.style.cursor = "not-allowed";
            }
        }

        function updateDepoRegionVisibility() {
            const selectedStatus = statusSelect.value;
            const showExtraFields = selectedStatus !== "Ontvangen";

            depoSelect.style.display = showExtraFields ? "block" : "none";
            regionSelect.style.display = showExtraFields ? "block" : "none";

            if (depoLabel) {
                depoLabel.style.display = showExtraFields ? "block" : "none";
            }

            if (regionLabel) {
                regionLabel.style.display = showExtraFields ? "block" : "none";
            }
        }

        async function savePackedState(box) {
            const formData = new FormData();
            formData.append("orderId", box.dataset.order);
            formData.append("productName", box.dataset.product);
            formData.append("packed", box.checked);

            await fetch("/Orders/UpdatePackedState", {
                method: "POST",
                body: formData
            });
        }

        packedCheckboxes.forEach(box => {
            updateIcon(box);

            box.addEventListener("change", async function () {
                updateIcon(this);

                await savePackedState(this);

                updateStatusAvailability();
            });
        });

        statusSelect.addEventListener("change", updateDepoRegionVisibility);

        // initial page state
        updateStatusAvailability();
        updateDepoRegionVisibility();
    </script>
</section>