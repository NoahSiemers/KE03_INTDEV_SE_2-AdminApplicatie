@model KE03_INTDEV_SE_2_Base.ViewModels.StaffViewModel

<h1>Nieuwe medewerker</h1>

<form asp-action="Create" method="post">

    <div class="mb-3">
        <label asp-for="FirstName">Voornaam</label>
        <input asp-for="FirstName" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="LastName">Achternaam</label>
        <input asp-for="LastName" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Email">E-mailadres</label>
        <input asp-for="Email" class="form-control" />
    </div>

    <div class="mb-3">

        <label asp-for="FunctionId">Functie</label>

        <select asp-for="FunctionId"
                asp-items="Model.Functions"
                class="form-select">

            <option value="">
                Kies een functie
            </option>

        </select>

    </div>

    <div class="form-check mb-3">

        <input asp-for="Active"
               class="form-check-input" />

        <label asp-for="Active"
               class="form-check-label">

            Actief

        </label>

    </div>
    <button type="submit" class="btn btn-success">
        Opslaan
    </button>

</form>